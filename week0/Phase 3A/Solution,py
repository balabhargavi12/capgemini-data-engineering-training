from pyspark.sql import SparkSession

# Create Spark Session
spark = SparkSession.builder.appName("Phase3A").getOrCreate()

# Messy Data
data = [
    (1, "Ravi", "Hyderabad", 25),
    (2, None, "Chennai", 32),
    (None, "Arun", "Hyderabad", 28),
    (4, "Meena", None, 30),
    (4, "Meena", None, 30),
    (5, "John", "Bangalore", -5)
]

columns = ["customer_id", "name", "city", "age"]

df = spark.createDataFrame(data, columns)

print("Original Data:")
df.show()

# ---------------- CLEANING ----------------

# Remove null customer_id
df_clean = df.dropna(subset=["customer_id"])

# Remove duplicates
df_clean = df_clean.dropDuplicates()

# Remove invalid age
df_clean = df_clean.filter(df_clean.age > 0)

print("Cleaned Data:")
df_clean.show()

# ---------------- VALIDATION ----------------
print("Original Count:", df.count())
print("Cleaned Count:", df_clean.count())

# ---------------- AGGREGATION ----------------
print("Customers per City:")
df_clean.groupBy("city").count().show()
